# Environment Variables for Sigil

# Twitch OAuth (https://dev.twitch.tv/console/apps)
# Public app: register http://localhost:17890/oauth/twitch/implicit + http://localhost:1420/oauth/twitch/implicit
# Confidential: register …/oauth/twitch/callback on those hosts; set client secret below.
SIGIL_TWITCH_CLIENT_ID=your_twitch_client_id_here
# Legacy (still works): CURSES_TWITCH_CLIENT_ID=…
# SIGIL_TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
# SIGIL_TWITCH_CLIENT_REDIRECT_LOCAL=https://your-app/oauth/twitch/callback
# SIGIL_TWITCH_IMPLICIT_REDIRECT_LOCAL=https://your-app/oauth/twitch/implicit

# Kick (https://kick.com/settings/developer) — localhost:17890/oauth/kick/callback (desktop) + localhost:1420 (browser host).
SIGIL_KICK_CLIENT_ID=your_kick_client_id_here
# Legacy (still works): CURSES_KICK_CLIENT_ID=…
SIGIL_KICK_CLIENT_SECRET=your_kick_client_secret_here
# Legacy (still works): CURSES_KICK_CLIENT_SECRET=…
# SIGIL_KICK_CLIENT_REDIRECT_LOCAL=https://your-app/oauth/kick/callback

# Optional: Google Fonts API (for custom font loading)
VITE_GOOGLE_FONTS_API_KEY=your_google_fonts_api_key_here
